APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail. Dev uses Mailpit (a local catcher). PRODUCTION must set a real SMTP
# host + credentials and a deliverable FROM address, or password-reset codes
# won't be delivered. A send failure is logged (channel `stack`) as
# "Password reset email failed to send", not surfaced to the user.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@businessinmap.com"
MAIL_FROM_NAME="BIM"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Payment gateways (wallet top-up). Do NOT commit real values to .env.
PAYMENTS_DEFAULT_GATEWAY=fawry
WALLET_TOPUP_MIN=10
WALLET_TOPUP_MAX=50000

# Fawry (Egypt). base_url = https://atfawry.com (prod) or
# https://atfawry.fawrystaging.com (staging). Get fresh credentials from Fawry;
# the ones previously hard-coded in Main.php must be rotated.
FAWRY_BASE_URL=https://atfawry.com
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_CURRENCY=EGP
FAWRY_RETURN_URL=

# Platform treasury account id (php artisan db:seed --class=PlatformAccountSeeder prints it)
BIM_PLATFORM_WALLET_USER_ID=

# Bearer token lifetime in minutes (default 90 days). Blank/absent = 90 days.
SANCTUM_TOKEN_EXPIRATION_MINUTES=129600
